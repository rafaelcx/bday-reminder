#!/bin/sh

# To enable this git pre-push hook you can run the following command on your terminal:
# git config core.hooksPath bin/git-hooks

set -e

CONTAINER="bday-reminder-bday-reminder-1"

echo "Running PHPUnit..."
docker exec -i "$CONTAINER" vendor/bin/phpunit test
echo

echo "Finding modified PHP files..."

PHP_FILES=$(git diff --name-only --diff-filter=AM @{upstream}...HEAD | grep '\.php$' || true)

if [ -n "$PHP_FILES" ]; then
    echo "Running PHPStan on modified PHP files..."
    echo
    
    docker exec -i "$CONTAINER" \
        vendor/bin/phpstan analyse --ansi --level max $PHP_FILES
else
    echo "No modified PHP files to analyse."
    echo
fi

echo "All checks passed!"
echo
